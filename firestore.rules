// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (Auth UID)
// Fields:
//   - uid: string (required)
//   - callsign: string (required, max length 50)
//   - totalScore: number
//   - maxStreak: number
//   - scenariosCompleted: number
//   - settings: map (optional keys: sound, notifications, hostility, hostilityAuto)
//
// Collection: operations
// Document ID: auto-generated
// Fields:
//   - userId: string (required, matches Auth UID)
//   - name: string (required)
//   - status: string (required, ['active', 'completed', 'archived'])
//   - scanPhoto: string (optional, data URL)
//   - scanIntent: string (optional)
//   - sectors: list (optional, objects with key, name, targets, etc.)
//   - completedTargets: list (strings)
//   - targetActions: map (id: action)
//   - totalScore: number
//   - streak: number
//   - maxStreak: number
//   - startedAt: string (ISO 8601)
//   - completedAt: string (ISO 8601)
//   - mood: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner(data) {
      return isAuthenticated() && request.auth.uid == data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              (request.auth.token.email == "morinmatt99@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'callsign']) &&
             data.uid is string &&
             data.callsign is string && data.callsign.size() > 0 && data.callsign.size() <= 50;
    }

    function isValidOperation(data) {
      return data.keys().hasAll(['userId', 'name', 'status']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 &&
             data.status in ['active', 'completed', 'archived'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /operations/{opId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidOperation(request.resource.data);
      allow update: if isAuthenticated() && 
                     (resource.data.userId == request.auth.uid) && 
                     isValidOperation(request.resource.data);
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Allow authenticated reads for system collections (e.g., StoreRecentApplet)
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
